generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMode {
  PAY_NOW
  PAY_LATER
}

model User {
  userId        String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  phone         String?
  role          Role      @default(CUSTOMER)
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastActiveAt  DateTime  @default(now()) // Used to track who is currently online

  workerProfile    WorkerProfile?
  bookingsAsCust   Booking[]       @relation("CustomerBookings")
  bookingsAsWorker Booking[]       @relation("WorkerBookings")
  ratingsGiven     Rating[]        @relation("CustomerRatings")
  ratingsReceived  Rating[]        @relation("WorkerRatings")
  messagesSent     Message[]       @relation("SentMessages")
  messagesReceived Message[]       @relation("ReceivedMessages")
  userActivities   UserActivity[]  @relation("UserActivities")
}

model WorkerProfile {
  workerId        String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  userId          String   @unique
  serviceCategory String
  skills          String?  
  pricing         String?
  serviceArea     String?
  availability    String?  
  portfolio       String?  
  ratingAverage   Float    @default(0.0)
}

model Booking {
  bookingId           String         @id @default(uuid())
  customer            User           @relation("CustomerBookings", fields: [customerId], references: [userId])
  customerId          String         
  worker              User           @relation("WorkerBookings", fields: [workerId], references: [userId])
  workerId            String         
  serviceCategory     String
  scheduledDateTime   DateTime
  serviceAddress      String
  specialInstructions String?        
  estimatedCost       Float?
  status              BookingStatus  @default(PENDING)
  paymentMode         PaymentMode    @default(PAY_LATER)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  payment             Payment?
  rating              Rating?
}

model Payment {
  paymentId     String        @id @default(uuid())
  booking       Booking       @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)
  bookingId     String        @unique 
  amount        Float
  paymentMethod String
  paymentStatus PaymentStatus @default(PENDING)
  transactionId String?       @unique
  timestamp     DateTime      @default(now())
}

model Rating {
  ratingId    String   @id @default(uuid())
  booking     Booking  @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)
  bookingId   String   @unique 
  customer    User     @relation("CustomerRatings", fields: [customerId], references: [userId])
  customerId  String   
  worker      User     @relation("WorkerRatings", fields: [workerId], references: [userId])
  workerId    String   
  ratingScore Int      // 1 to 5
  reviewText  String?  
  timestamp   DateTime @default(now())
}

model Message {
  messageId      String   @id @default(uuid())
  conversationId String   // Group conversations between customers and workers
  sender         User     @relation("SentMessages", fields: [senderId], references: [userId])
  senderId       String   
  receiver       User     @relation("ReceivedMessages", fields: [receiverId], references: [userId])
  receiverId     String   
  messageText    String   
  status         String   @default("SENT") // SENT, DELIVERED, READ
  timestamp      DateTime @default(now())
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String?  // optional — anonymous tickets allowed
  type        String   // e.g. "PAYMENT", "BOOKING", "ACCOUNT", "OTHER"
  subject     String
  description String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  excerpt   String
  category  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?  // lucide icon name string e.g. "Wrench"
  createdAt   DateTime @default(now())
}

model UserActivity {
  id        String   @id @default(uuid())
  user      User     @relation("UserActivities", fields: [userId], references: [userId], onDelete: Cascade)
  userId    String
  action    String   // "LOGIN" or "LOGOUT"
  ipAddress String?  
  timestamp DateTime @default(now())
}
